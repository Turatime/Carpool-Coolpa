# [Backend Configuration]
# ----------------------
# URL สำหรับเชื่อมต่อฐานข้อมูล (ค่าเริ่มต้นใช้ SQLite)
# DATABASE_URL ถูกกำหนดใน docker-compose.yml แล้ว

# คีย์ลับสำหรับการแฮชรหัสผ่านและสร้าง JWT Token (กรุณาเปลี่ยนเป็นค่าอื่นที่คาดเดายาก)
SECRET_KEY=carpool_coolpa_super_secret_key_2024

# อัลกอริทึมที่ใช้สำหรับ JWT
ALGORITHM=HS256

# เวลาหมดอายุของ Token (นาที)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# [Frontend Configuration]
# -----------------------
# URL ของ Backend API สำหรับให้ Frontend เรียกใช้
API_URL=http://localhost:8000/api
